# --- Secrets (gitignored — never commit real values) -------------------------

# Kimi Code API key (https://www.kimi.com/code → API keys). Powers BOTH agent
# providers: claude-code (ANTHROPIC_API_KEY) and kimi-code (KIMI_MODEL_API_KEY).
KIMI_API_KEY=

# GitHub token for `gh` inside sandboxes (issue read/close, branch push).
GH_TOKEN=

# Context7 API key (optional — higher rate limits for the live-docs MCP server).
CONTEXT7_API_KEY=

# Railway project token (optional — injected only into issue sandboxes that
# declare `requires_railway: true`). Never use an account/workspace API token.
RAILWAY_TOKEN=

# Deterministic Railway target — load-bearing config, not a hint. `railway list`
# fails with token auth; agents must always work against the pinned project.
# RAILWAY_PROJECT_ID=
# RAILWAY_ENVIRONMENT_ID=

# --- Orchestrator knobs (optional) -------------------------------------------

# Agent provider: claude-code (default, Claude Code CLI on Kimi) | kimi-code.
# SANDCASTLE_AGENT_PROVIDER=claude-code

# Per-role context-window knobs (default 1048576; on 401 the ladder falls back
# to 262144 automatically):
# SANDCASTLE_KIMI_WINDOW_PLANNER=1048576
# SANDCASTLE_KIMI_WINDOW_IMPLEMENTER=1048576
# SANDCASTLE_KIMI_WINDOW_REVIEWER=1048576

# Maximum disjoint issue PRs executed in one planner cycle:
# SANDCASTLE_MAX_CONCURRENT_ISSUES=2
# Explicitly reviewed issue-number pairs that may execute concurrently:
# SANDCASTLE_DISJOINT_ISSUE_PAIRS=16:17

# plan→execute→merge cycles per run (set to 1 for a smoke test):
# MAX_ITERATIONS=10

# Idle timeouts (seconds) before a stuck agent iteration is aborted:
# SANDCASTLE_IMPLEMENTER_IDLE_TIMEOUT_SECONDS=300
# SANDCASTLE_REVIEWER_IDLE_TIMEOUT_SECONDS=180
